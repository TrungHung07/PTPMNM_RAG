# Copy file này thành .env và điền giá trị phù hợp
# cp .env.example .env

# PostgreSQL
POSTGRES_DB=ragdb
POSTGRES_USER=raguser
POSTGRES_PASSWORD=ragpass

# Dùng khi chạy app local (kết nối vào postgres trong docker)
DATABASE_URL=postgresql://raguser:ragpass@localhost:5432/ragdb

# Dùng khi chạy app trong docker (kết nối theo service name)
# DATABASE_URL=postgresql://raguser:ragpass@postgres:5432/ragdb

# Ollama (mặc định khi chạy local)
OLLAMA_BASE_URL=http://localhost:11434

# Ollama (khi app chạy trong docker)
# OLLAMA_BASE_URL=http://ollama:11434
